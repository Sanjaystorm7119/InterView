# ============================================================
# HireEva Environment Variables — copy to .env and fill in
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:PASSWORD@localhost/Hire

# --- JWT ---
SECRET_KEY=your-64-char-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenRouter (AI) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# --- Vapi (Voice AI) ---
# Get your key at https://dashboard.vapi.ai
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key

# --- Resend (Email) ---
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Stripe (Payments) ---
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Sentry (Error Tracking) ---
# Get your DSN at https://sentry.io
SENTRY_DSN=https://...@sentry.io/...
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# --- URLs ---
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_HOST_URL=http://localhost:3000/interview
HOST_URL=http://localhost:3000/interview
NEXT_PUBLIC_API_URL=http://localhost:8000
